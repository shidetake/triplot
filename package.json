{
  "name": "triplot",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm -w @triplot/web run dev",
    "build": "npm -w @triplot/web run build",
    "start": "npm -w @triplot/web run start",
    "lint": "npm -w @triplot/web run lint",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm -w @triplot/web run test:watch",
    "db:types": "bash scripts/gen-db-types.sh",
    "db:types:check": "bash scripts/check-db-types.sh",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "supabase": "^2.95.5"
  }
}
