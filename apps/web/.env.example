# Supabase
# Project URL（https://app.supabase.com/project/<id>/settings/api）
NEXT_PUBLIC_SUPABASE_URL=
# Publishable key（旧 anon key と同じ役割。クライアントに埋めて OK、RLS で守る）
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps Platform
# Maps JavaScript API と Places API を有効化したプロジェクトの API キー
# HTTP referrer 制限を必ずかけること
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
